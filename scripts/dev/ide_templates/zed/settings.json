{
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "languages": {
    "TypeScript": {
      "format_on_save": "on"
    },
    "TSX": {
      "format_on_save": "on"
    },
    "JavaScript": {
      "format_on_save": "on"
    },
    "JSON": {
      "format_on_save": "on"
    }
  },
  "lsp": {
    "typescript-language-server": {
      "settings": {
        "typescript": {
          "tsdk": "node_modules/typescript/lib"
        }
      }
    }
  }
}
