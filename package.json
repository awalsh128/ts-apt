{
  "name": "ts-apt",
  "version": "0.0.0-semantically-released",
  "description": "TypeScript APT and APT-fast package management library",
  "author": "Andrew Walsh",
  "license": "Apache-2.0",
  "keywords": [
    "apt",
    "apt-cache",
    "apt-get",
    "apt-fast",
    "helper"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/awalsh128/ts-apt.git"
  },
  "files": [
    "dist/src",
    "!dist/test",
    "scripts",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/types.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      },
      "require": {
        "types": "./dist/src/index.d.cts",
        "default": "./dist/src/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "check:latest-action-pin": "node ./dev_scripts/check_latest_action_pin.mjs",
    "check:latest-action-pins": "node ./dev_scripts/check_latest_action_pin.mjs --scan",
    "check:configs": "node ./dev_scripts/verify_configs.mjs",
    "check": "npm run check:latest-action-pin && npm run check:configs",
    "setup:dev": "node ./dev_scripts/setup_devenv.mjs",
    "docs:api": "typedoc",
    "docs:api-md": "typedoc --options typedoc.json",
    "docs": "npm run docs:api && npm run docs:api-md",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "lint": "eslint src test --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --exclude test/ubuntu.integration.test.ts --exclude test/ubuntu.mutating.integration.test.ts --coverage",
    "test:integration": "vitest run --coverage test/ubuntu.integration.test.ts test/ubuntu.mutating.integration.test.ts",
    "test:integration:docker": "TS_APT_FORCE_DEVCONTAINER=true vitest run --coverage test/ubuntu.integration.test.ts test/ubuntu.mutating.integration.test.ts",
    "test": "npm run test:unit && npm run test:integration",
    "dev": "vitest"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@devcontainers/cli": "^0.87.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "internet-message": "^1.0.0",
    "semantic-release": "^25.0.5",
    "type-coverage": "^2.29.7",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
