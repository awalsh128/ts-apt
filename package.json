{
  "name": "ts-apt",
  "version": "0.1.0",
  "description": "TypeScript APT and APT-fast package management library",
  "author": "Andrew Walsh",
  "license": "Apache-2.0",
  "keywords": [
    "apt",
    "apt-fast",
    "helper"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/awalsh128/ts-apt.git"
  },
  "files": [
    "dist/src",
    "!dist/test",
    "scripts",
    "docs/api",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      },
      "require": {
        "types": "./dist/src/index.d.cts",
        "default": "./dist/src/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "docs:api": "typedoc",
    "docs:api:check": "npm run docs:api && git diff --exit-code -- docs/api",
    "release:preflight": "node dev_scripts/check_release_tag.mjs",
    "lint": "eslint src test --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "dev": "vitest"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "internet-message": "^1.0.0",
    "type-coverage": "^2.29.7",
    "typedoc": "^0.28.19",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9",
    "winston": "^3.19.0"
  }
}
