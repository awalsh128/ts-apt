{
  "name": "ts-apt",
  "version": "0.1.0",
  "description": "TypeScript APT and APT-fast package management library",
  "author": "Andrew Walsh",
  "license": "Apache-2.0",
  "keywords": [
    "apt",
    "apt-fast",
    "helper"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/awalsh128/ts-apt.git"
  },
  "files": [
    "dist/src",
    "!dist/test",
    "docs/api",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "docs:api": "typedoc",
    "docs:api:check": "npm run docs:api && git diff --exit-code -- docs/api",
    "release:preflight": "node scripts/check-release-tag.mjs",
    "lint": "eslint src test --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "dev": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^9.29.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
