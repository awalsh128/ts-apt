{
  "extends": "./tsconfig.base.json",
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "scripts/**/*.mts",
    "scripts/dist/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "compilerOptions": {
    "types": [
      "node",
      "vitest/globals"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}